generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String         @id @default(cuid())
  email            String         @unique
  name             String
  role             UserRole       @default(VENDOR_PIC)
  password         String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  createdPersonnel Personnel[]
  createdProjects  Project[]
  rateAlerts       RateAlert[]
  rateNormEdits    RateNorm[]
  configEdits      SystemConfig[]
  createdVendors   Vendor[]
  cvUploads        PersonnelCV[]
}

model JobType {
  id                   String                @id @default(cuid())
  name                 String                @unique
  order                Int                   @default(0)
  personnel            Personnel[]
  projectRateOverrides ProjectRateOverride[]
  rateAlerts           RateAlert[]
  rateNorms            RateNorm[]
}

model TechStack {
  id                   String                @id @default(cuid())
  name                 String                @unique
  order                Int                   @default(0)
  personnel            Personnel[]
  projectRateOverrides ProjectRateOverride[]
  rateAlerts           RateAlert[]
  rateNorms            RateNorm[]
}

model Level {
  id                   String                @id @default(cuid())
  name                 String                @unique
  order                Int
  personnel            Personnel[]
  projectRateOverrides ProjectRateOverride[]
  rateAlerts           RateAlert[]
  rateNorms            RateNorm[]
}

model Domain {
  id                   String                @id @default(cuid())
  name                 String                @unique
  order                Int                   @default(0)
  personnel            Personnel[]
  projectRateOverrides ProjectRateOverride[]
  rateNorms            RateNorm[]
}

model MarketConfig {
  id                  String   @id @default(cuid())
  code                String   @unique
  name                String
  marketRateFactorPct Float    @default(0.80)
  isActive            Boolean  @default(true)
  order               Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model RateNorm {
  id            String    @id @default(cuid())
  jobTypeId     String
  techStackId   String
  levelId       String
  domainId      String
  rateMin       Float
  rateNorm      Float
  rateMax       Float
  effectiveDate DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  createdById   String
  marketCode    String    @default("ENGLISH")
  createdBy     User      @relation(fields: [createdById], references: [id])
  domain        Domain    @relation(fields: [domainId], references: [id])
  jobType       JobType   @relation(fields: [jobTypeId], references: [id])
  level         Level     @relation(fields: [levelId], references: [id])
  techStack     TechStack @relation(fields: [techStackId], references: [id])

  @@unique([jobTypeId, techStackId, levelId, domainId, marketCode])
  @@index([marketCode])
}

model SystemConfig {
  id          String    @id @default(cuid())
  key         ConfigKey @unique
  value       String
  updatedAt   DateTime  @updatedAt
  updatedById String
  updatedBy   User      @relation(fields: [updatedById], references: [id])
}

model ProjectRateOverride {
  id                String    @id @default(cuid())
  projectId         String
  jobTypeId         String
  techStackId       String
  levelId           String
  domainId          String
  customBillingRate Float
  setById           String
  setAt             DateTime  @default(now())
  domain            Domain    @relation(fields: [domainId], references: [id])
  jobType           JobType   @relation(fields: [jobTypeId], references: [id])
  level             Level     @relation(fields: [levelId], references: [id])
  project           Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  techStack         TechStack @relation(fields: [techStackId], references: [id])

  @@unique([projectId, jobTypeId, techStackId, levelId, domainId])
}

model RateAlert {
  id                  String      @id @default(cuid())
  jobTypeId           String
  techStackId         String
  levelId             String
  normRate            Float
  actualAvgVendorRate Float
  driftPct            Float
  triggeredById       String
  triggeredAt         DateTime    @default(now())
  status              AlertStatus @default(PENDING)
  note                String?
  jobType             JobType     @relation(fields: [jobTypeId], references: [id])
  level               Level       @relation(fields: [levelId], references: [id])
  techStack           TechStack   @relation(fields: [techStackId], references: [id])
  triggeredBy         User        @relation(fields: [triggeredById], references: [id])
}

model Vendor {
  id               String       @id @default(cuid())
  name             String
  contactName      String
  contactEmail     String
  contactPhone     String?
  companySize      Int?
  languageStrength String[]
  status           VendorStatus @default(ACTIVE)
  startDate        DateTime?
  notes            String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  createdById      String
  marketCode       String       @default("ENGLISH")
  personnel        Personnel[]
  createdBy        User         @relation(fields: [createdById], references: [id])
}

model Personnel {
  id               String          @id @default(cuid())
  vendorId         String
  fullName         String
  jobTypeId        String
  techStackId      String?         // Optional — BA/PM may not have a tech stack
  levelId          String
  domainId         String?         // Optional — not all roles need domain
  englishLevel     EnglishLevel    @default(INTERMEDIATE)
  leadership       Boolean         @default(false)
  leadershipNote   String?
  vendorRateActual Float?
  status           PersonnelStatus @default(AVAILABLE)
  interviewStatus  InterviewStatus @default(NEW)
  notes            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  createdById      String
  assignments      Assignment[]
  cvs              PersonnelCV[]
  createdBy        User            @relation(fields: [createdById], references: [id])
  domain           Domain?         @relation(fields: [domainId], references: [id])
  jobType          JobType         @relation(fields: [jobTypeId], references: [id])
  level            Level           @relation(fields: [levelId], references: [id])
  techStack        TechStack?      @relation(fields: [techStackId], references: [id])
  vendor           Vendor          @relation(fields: [vendorId], references: [id])
}

model PersonnelCV {
  id          String    @id @default(cuid())
  personnelId String
  label       String    // e.g. "CV v1 - Backend", "Updated Mar 2026"
  url         String    // Google Drive link, OneDrive, etc.
  isLatest    Boolean   @default(false)
  notes       String?
  uploadedAt  DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  uploadedById String
  personnel   Personnel @relation(fields: [personnelId], references: [id], onDelete: Cascade)
  uploadedBy  User      @relation(fields: [uploadedById], references: [id])

  @@index([personnelId])
}


model Project {
  id            String                @id @default(cuid())
  name          String
  clientName    String
  startDate     DateTime
  endDate       DateTime?
  status        ProjectStatus         @default(ACTIVE)
  notes         String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  createdById   String
  marketCode    String                @default("ENGLISH")
  assignments   Assignment[]
  createdBy     User                  @relation(fields: [createdById], references: [id])
  rateOverrides ProjectRateOverride[]
}

model Assignment {
  id                  String           @id @default(cuid())
  personnelId         String
  projectId           String
  roleInProject       String?
  billingRateOverride Float?
  billingRateNote     String?
  vendorRateOverride  Float?
  startDate           DateTime
  endDate             DateTime?
  status              AssignmentStatus @default(ACTIVE)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  personnel           Personnel        @relation(fields: [personnelId], references: [id])
  project             Project          @relation(fields: [projectId], references: [id])

  @@index([projectId])
  @@index([personnelId])
}

enum UserRole {
  DU_LEADER
  VENDOR_PIC
}

enum ConfigKey {
  OVERHEAD_RATE_PCT
  MARKET_RATE_FACTOR_PCT
  DRIFT_ALERT_THRESHOLD_PCT
}

enum AlertStatus {
  PENDING
  FLAGGED_FOR_DU_LEADER
  RESOLVED
  DISMISSED
}

enum VendorStatus {
  ACTIVE
  INACTIVE
  ON_HOLD
}

enum EnglishLevel {
  BASIC
  INTERMEDIATE
  ADVANCED
  FLUENT
}

enum PersonnelStatus {
  AVAILABLE
  ON_PROJECT
  ENDED
}

enum InterviewStatus {
  NEW
  SCREENING
  TECHNICAL_TEST
  INTERVIEW
  PASSED
  FAILED
}

enum ProjectStatus {
  ACTIVE
  ON_HOLD
  ENDED
}

enum AssignmentStatus {
  ACTIVE
  ENDED
}
